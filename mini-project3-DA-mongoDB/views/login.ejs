<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <!-- <link rel="stylesheet" href="/stylesheets/style.css" /> -->
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-900 m-0 p-0">
    <% if (message) { %>
        <div id="toast"
            class="fixed top-5 right-5 bg-green-600 text-white px-4 py-2 rounded shadow-lg opacity-0 transition-opacity duration-500">
            <%= message %>
        </div>
    <% } %>
    <span id="toastMessage" data-message="<%= message %>" hidden></span>

    <div class="bg-zinc-900 w-full min-h-screen p-10 text-white">
        <h1 class=" text-3xl mb-3 tracking-tighter">Login Your Account</h1>
        <form action="/login" method="post">
          <input
            name="email"
            class="mt-2 block w-1/3 rounded-md outline-none bg-zinc-800 px-5 py-2"
            type="text"
            placeholder="Enter Email Id"
            required
          />
          <input
            name="password"
            class="mt-2 block w-1/3 rounded-md outline-none bg-zinc-800 px-5 py-2"
            type="password"
            placeholder="Enter Password"
            required
          />

          <input class="mt-2 bg-blue-600 px-3 py-2 rounded-md" type="submit" value="Login Account" />

        </form>

        <p class="text-gray-300 mt-4">
            Create an account?
            <a href="/" class="text-blue-400 hover:text-blue-300 underline">
                Register
            </a>
        </p>
    </div>


    <script src="/javascripts/script.js"></script>
</body>
</html>