<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-900">
    
    <% if (message) { %>
        <div id="toast"
            class="fixed top-5 right-5 bg-green-600 text-white px-4 py-2 rounded shadow-lg opacity-0 transition-opacity duration-500">
            <%= message %>
        </div>
    <% } %>
    <span id="toastMessage" data-message="<%= message %>" hidden></span>

    <div class="w-full h-full bg-zinc-900 p-10 text-white">
        <div class="nav mb-10 text-xl">
            <a class="text-blue-500" href="/">Back to Home</a>
        </div>
        <h1 class="text-white text-3xl mb-3 tracking-tighter">All User</h1>
        <div class="users flex gap-5 flex-wrap">
            <% users.forEach((users) => { %>
                <div class="user w-72 p-5 bg-zinc-800 rounded-lg">
                    <div class="w-full h-52 roundedl-lgs bg-zinc-600 overflow-hidden">
                        <img src="<%= users.imgurl %>" alt="<%= users.username %>" class="w-full h-full object-cover" />
                    </div>
                    <h3 class="text-xl mt-3 tracking-tighter"> <%= users.name %> </h3>
                    <h4 class="text-zinc-400"> <%= users.username %> </h4>
                    <h5 class="text-zinc-500"> <%= users.email %> </h5>
                    <div class="flex gap-3 mt-5">
                        <a class="text-green-500" href="/edit/<%= users.name %>">Edit</a>
                        <a class="text-red-500" href="">Delete</a>
                    </div>
                </div>
            <% }) %>        
        </div>
    </div>
</body>
</html>