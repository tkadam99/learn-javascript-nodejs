<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Task</title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-900">
    <div class="main w-full min-h-screen p-10 text-white">
        <a class="text-blue-500 inline-block mb-10" href="/">Go Back to Home</a>
        <div class="form p-10 text-white">
        <form action="/edit/<%= editTask[0].name %>" method="post">
            <input
                name="newTitle"
                value='<%= editTask[0].name.replace(".txt", "") %>'
                class="block w-1/3 rounded outline-none bg-zinc-800 px-5 py-2"
                type="text"
                placeholder="Title"
            />
            <textarea
                name="newDescription"
                value=""
                class="mt-2 block w-full resize-none rounded outline-none bg-zinc-800 px-5 py-2"
                placeholder="Task Description"
            ><%= editTask[0].desc %>
            </textarea>

          <input class="mt-4 bg-green-600 px-4 py-2 rounded-md cursor-pointer" type="submit" value="Update Task" />

        </form>
      </div>
    </div>
</body>
</html>